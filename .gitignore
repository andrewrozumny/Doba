*.dSYM

# === Swift Package Manager ===
.build/
.swiftpm/
Package.resolved

# === Secrets — NEVER commit ===
# Phase 4 (Claude API) keeps the key in Keychain or a gitignored config.
*.xcconfig
Secrets.xcconfig
.env
.env.*
*.secret
*.secrets
secrets.json
config/secrets*

