# === Generated Xcode project ===
# project.yml is the source of truth; the .xcodeproj is regenerated with
# `xcodegen generate` and must NOT be committed.
Doba.xcodeproj/

# === Local signing & identity (bundle prefix + Team ID) ===
# Copy Config/Doba.xcconfig.example → Config/Doba.xcconfig and set your values.
# The real one is never committed; the .example template is.
Config/Doba.xcconfig

# === Xcode ===
build/
DerivedData/
*.xcuserstate
xcuserdata/
*.xcscmblueprint
*.xccheckout
*.moved-aside
*.hmap
*.ipa
