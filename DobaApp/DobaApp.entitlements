<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- The App Sandbox is enabled so the app resolves the SAME App Group
	     container as the (always-sandboxed) widget extension — App Group
	     containers are a sandbox construct, and a non-sandboxed app does not
	     reliably share them. See docs/DECISIONS.md (D12, revised).
	     Later phases add the entitlements they need: calendars (Phase 2),
	     network.client (Phase 4). -->
	<key>com.apple.security.app-sandbox</key>
	<true/>
	<!-- Shared container with DobaWidget. Must match AppGroup.identifier in
	     DobaKit and the widget's entitlements. -->
	<key>com.apple.security.application-groups</key>
	<array>
		<string>group.$(DOBA_BUNDLE_PREFIX).Doba</string>
	</array>
	<!-- Phase 2: read-only access to the system Calendar (EventKit). -->
	<key>com.apple.security.personal-information.calendars</key>
	<true/>
	<!-- Phase 4: outbound HTTPS to the Claude API for NL task parsing. -->
	<key>com.apple.security.network.client</key>
	<true/>
</dict>
</plist>
